{
  "id": "carpool",
  "name": "Carpool Coordinator",
  "version": "1.0.0",
  "description": "Organize recurring carpool rotations for school, sports, or activities — assign drivers by day, handle swap requests, and surface pickups on the shared family calendar.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "organization",
  "tags": ["carpool", "driving", "rotation", "scheduling", "calendar"],
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "db_plaintext_columns": ["date"],
  "row_policies": {
    "carpools": {
      "kind": "adult_writable"
    },
    "assignments": {
      "kind": "adult_writable"
    },
    "swap_requests": {
      "kind": "adult_writable"
    }
  },
  "exports": ["calendar_events"],
  "store_acls": {
    "calendar_events": {
      "write": { "require_role": "adult" }
    }
  },
  "publishes": ["carpool.assigned", "carpool.swap_requested", "carpool.swap_accepted"],
  "nav": { "label": "Carpool" },
  "widget": { "label": "Carpool", "size": "small" },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "icon": "🚗",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["upcoming_carpools", "driver_load"]
  }
}
